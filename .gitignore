# Large / generated artifacts — rebuild these on each device, don't commit them
*.engine
*.mp4
*.onnx
__pycache__/
*.pyc

# Runtime data mount: keep the dir (bind-mounted to the container's /data) but
# not its contents (videos, images, engines are generated/large).
container/data/*
!container/data/.gitkeep

# runtime log + local backup — not part of the package
log
*.log
webui.bak/
.claude/settings.local.json

# Exception to the *.mp4 rule above: bundle the demo clip(s) under videos/ so the UI's
# default /data/videos source is never empty on a fresh clone. (These add ~31MB to the repo.)
!videos/
!videos/*.mp4
